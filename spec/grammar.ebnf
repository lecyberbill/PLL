(*
 * PLL v2 — Formal Grammar (EBNF/ISO 14977)
 * ==========================================
 * Layer 0: Lexical & Syntactic Specification
 * Status: Foundation Draft
 *)

(* ────────────────────────────────────────────
   0. Lexical Elements
   ──────────────────────────────────────────── *)

letter          = "A" | ... | "Z" | "a" | ... | "z" | "_" ;
digit           = "0" | ... | "9" ;
ident_char      = letter | digit ;
string_char     = ? any Unicode except `"` or `\` ? | escape_seq ;

ident           = letter , { ident_char } ;
decimal         = digit , { digit } ;
float           = decimal , "." , decimal , [ "e" , [ "+" | "-" ] , decimal ] ;
string          = '"' , { string_char } , '"' ;
escape_seq      = "\\" , ( "n" | "t" | "r" | '"' | "\\" ) ;

(* ────────────────────────────────────────────
   1. Program Structure
   ──────────────────────────────────────────── *)

program         = { statement } , [ eof ] ;

statement       = var_decl
                | type_decl
                | proto_decl
                | cap_decl
                | contract_decl
                | agent_decl
                | assignment
                | transform_stmt
                | converge_block
                | par_block
                | fork_stmt
                | meta_exec
                | if_stmt
                | ui_block
                | route_block
                | emit_stmt
                | render_stmt
                | db_op
                | block
                ;

block           = ":" , [ newline ] , indented_statements ;
indented_statements = { statement } ;  (* indentation-scoped *)

(* ────────────────────────────────────────────
   2. Variables & Belief States
   ──────────────────────────────────────────── *)

var_decl        = ident , "=" , "?" , "(" , string , ")" , [ provenance ] ;
assignment      = ident , "=" , expression ;

(* ────────────────────────────────────────────
   3. Type System
   ──────────────────────────────────────────── *)

type_decl       = "t" , ident , list ;
list            = "[" , [ field , { "," , field } ] , "]" ;
field           = ident , [ ":" , type_ref , [ "?" ] ] ;   (* ? = optional field *)
type_ref        = "String" | "bool" | "num" | "dist" | "belief" | ident
                | type_ref , "[" , expression , "]" ;      (* parametric *)
                
prob_type       = "belief" , "<" , type_ref , ">"          (* belief<T> *)
                | "dist" , "<" , type_ref , ">" ;          (* dist<T> *)

(* ────────────────────────────────────────────
   4. Protocol & Message
   ──────────────────────────────────────────── *)

proto_decl      = "p" , ident , ":" , block ;
proto_block     = { msg_decl | constraint_stmt } ;
msg_decl        = "msg" , ident , list ;
constraint_stmt  = "constraint" , expression ;

(* ────────────────────────────────────────────
   5. Capability
   ──────────────────────────────────────────── *)

cap_decl        = "cap" , ident , func_sig
                , { cost_spec | requires_spec | safety_spec } ;
func_sig        = "[" , [ params ] , "]" , [ "->" , "[" , [ params ] , "]" ] ;
cost_spec       = "cap" , "." , "cost" , ":" , expression ;
requires_spec   = "cap" , "." , "requires" , ":" , string ;
safety_spec     = "cap" , "." , "safety" , ":" , list ;
params          = param , { "," , param } ;
param           = ident , [ ":" , type_ref ] ;

(* ────────────────────────────────────────────
   6. Contract
   ──────────────────────────────────────────── *)

contract_decl   = "contract" , ident , ":" , block ;
contract_block  = { pre_stmt | post_stmt | invariant_stmt } ;
pre_stmt        = "pre" , ":" , expression ;
post_stmt       = "post" , ":" , expression ;
invariant_stmt  = "invariant" , ":" , expression ;

(* ────────────────────────────────────────────
   7. Transformation
   ──────────────────────────────────────────── *)

transform_stmt  = ident , "=" , expression , "=>"
                , ( string | type_ref )
                , [ "under" , ident ]
                , [ verify_block ] ;
verify_block    = ":" , newline , indented_verify ;
indented_verify = { verify_cond | retry_stmt } ;
verify_cond     = "v" , expression ;
retry_stmt      = "r" , "(" , retry_param , { "," , retry_param } , ")" ;
retry_param     = ( "temp" | "attempts" | "model" | "few_shot" ) , ( "+=" | "=" ) , expression ;

(* ────────────────────────────────────────────
   8. Convergence
   ──────────────────────────────────────────── *)

converge_block  = "converge" , "(" , converge_param , { "," , converge_param } , ")" , block ;
converge_param  = "target" , ":" , expression
                | "patience" , ":" , expression
                | "max_steps" , ":" , expression ;

(* ────────────────────────────────────────────
   9. Parallel Execution
   ──────────────────────────────────────────── *)

par_block       = "par" , ":" , block
                , [ "join" , ident , ":" , ( ident | merge_block ) ] ;
merge_block     = "merge" , "(" , ident , { "," , ident } , ")" , [ "~>" , string , "(" , merge_param , ")" ] ;
merge_param     = "threshold" , ":" , expression ;

(* ────────────────────────────────────────────
   10. Semantic Branching
   ──────────────────────────────────────────── *)

fork_stmt       = "fork" , expression , block ;
fork_block      = { case_stmt , [ else_stmt ] } ;
case_stmt       = "c" , string , "(" , expression , ")" , block ;
else_stmt       = "else" , block ;

if_stmt         = "if" , expression , block , [ "else" , block ] ;

(* ────────────────────────────────────────────
   11. Meta-Execution
   ──────────────────────────────────────────── *)

meta_exec       = "`" , expression , "`" ;

(* ────────────────────────────────────────────
   12. Provenance & Metadata
   ──────────────────────────────────────────── *)

provenance      = "@" , "{" , prov_entry , { "," , prov_entry } , "}" ;
prov_entry      = ident , ":" , expression ;

(* ────────────────────────────────────────────
   13. Agent Declaration
   ──────────────────────────────────────────── *)

agent_decl      = "agent" , string , [ "on" , ident ] , block ;
agent_block     = { state_decl | on_handler } ;
state_decl      = ident , "=" , "?" , "(" , string , ")" , [ "@" , "persistent" , ":" , bool_lit ] ;
on_handler      = "on" , ident , block ;

(* ────────────────────────────────────────────
   14. UI & Routing
   ──────────────────────────────────────────── *)

ui_block        = "ui" , ":" , block ;
ui_content      = { string | interpolation } ;
interpolation   = "{" , expression , "}" ;

route_block     = "route" , string , block ;

(* ────────────────────────────────────────────
   15. I/O & Persistence
   ──────────────────────────────────────────── *)

emit_stmt       = "emit" , expression ;
render_stmt     = "render" , expression ;
db_op           = db_set | db_get ;
db_set          = "db_set" , "(" , expression , "," , expression , ")" ;
db_get          = "db_get" , "(" , expression , ")" ;

(* ────────────────────────────────────────────
   16. Expressions
   ──────────────────────────────────────────── *)

expression      = primary
                | unary_op , expression
                | expression , binary_op , expression
                | expression , "~" , expression          (* semantic similarity *)
                | expression , "~>" , expression          (* belief propagation *)
                | expression , "=>" , ( string | type_ref ) ;  (* inline transform *)

primary         = literal
                | ident
                | list_literal
                | "(" , expression , ")"
                | "input" , "(" , string , ")"
                | "merge" , "(" , args , ")"
                | meta_exec
                ;

literal         = string | decimal | float | bool_lit ;
bool_lit        = "true" | "false" ;
list_literal    = "[" , [ expression , { "," , expression } ] , "]" ;
args            = expression , { "," , expression } ;

unary_op        = "!" | "-" | "~" ;
binary_op       = "+" | "-" | "*" | "/" | "==" | "!=" | ">" | "<" | ">=" | "<="
                | "and" | "or" ;

(* ────────────────────────────────────────────
   17. Comments
   ──────────────────────────────────────────── *)

comment         = "#" , { ? any character except newline ? } , newline ;
